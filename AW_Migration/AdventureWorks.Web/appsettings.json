{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AdventureWorksDb": "Server=localhost,1433;Database=AdventureWorks2019;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Authentication": {
    "Cookie": {
      "LoginPath": "/Account/Login",
      "LogoutPath": "/Account/Logout",
      "AccessDeniedPath": "/Account/AccessDenied",
      "ExpireTimeSpan": "00:30:00",
      "SlidingExpiration": true
    }
  }
}