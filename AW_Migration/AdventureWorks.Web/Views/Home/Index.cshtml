@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to Adventure Works</h1>
    <p class="lead">Your premier source for outdoor and cycling equipment.</p>
    
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="alert alert-success mt-4">
            <i class="bi bi-check-circle"></i> You are logged in as @User.Identity.Name
        </div>
    }
    else
    {
        <div class="mt-4">
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
                <i class="bi bi-box-arrow-in-right"></i> Login to Continue
            </a>
        </div>
    }
</div>